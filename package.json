  ],
  "author": "Alexander Hagen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/alexander-hagen/node-api-revolut/issues"
  },
  "homepage": "https://github.com/alexander-hagen/node-api-revolut#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "istanbul-badges-readme": "^1.9.0",
    "jest": "^30.2.0",
    "jest-extended": "^7.0.0"
  },
  "directories": {
    "lib": "lib",
    "test": "test"
  }
