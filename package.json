{
  "name": "node-api-revolut",
  "version": "0.0.1",
  "description": "Non-official implementation of Revolut's Crypto API's",
  "main": "index.js",
  "jest": {
    "coverageReporters": [
      "json-summary",
      "text",
      "lcov"
    ]
  },
  "scripts": {
    "test": "jest --coverage --passWithNoTests --verbose",
    "badges": "istanbul-badges-readme --colors=red:50,yellow:80",
    "patch": "npm version patch --no-git-tag-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexander-hagen/node-api-revolut.git"
  },
  "keywords": [
